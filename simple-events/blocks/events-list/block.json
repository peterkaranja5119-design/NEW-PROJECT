{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "simple-events/events-list",
	"title": "Events List",
	"category": "widgets",
	"icon": "calendar-alt",
	"description": "Display a list of upcoming, past, or all events.",
	"keywords": [ "event", "events", "calendar" ],
	"textdomain": "simple-events",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"limit": {
			"type": "number",
			"default": 5
		},
		"scope": {
			"type": "string",
			"default": "upcoming"
		},
		"category": {
			"type": "string",
			"default": ""
		},
		"showExcerpt": {
			"type": "boolean",
			"default": true
		}
	},
	"editorScript": "file:./index.js",
	"style": "simple-events"
}
